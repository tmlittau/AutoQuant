# AutoQuant -- docker-compose environment.
# Copy this to ``.env`` (same directory as docker-compose.yml) and fill in.

# --- REQUIRED --------------------------------------------------------------

# Strong random Django secret. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
DJANGO_SECRET_KEY=

# Comma-separated. Must include the public Cloudflare hostname AND localhost
# (so the backend health check works inside the container).
DJANGO_ALLOWED_HOSTS=subex.example.com,localhost,127.0.0.1

# Full origin URLs (incl. scheme) trusted for CSRF. Must include the public
# Cloudflare-fronted hostname.
DJANGO_CSRF_TRUSTED_ORIGINS=https://subex.example.com

# --- OPTIONAL --------------------------------------------------------------

# Host port the frontend (nginx) binds to. Cloudflare Tunnel points here.
AUTOQUANT_HOST_PORT=3000

# Alpha Vantage API key. You can also enter it later via Settings in the UI.
AV_API_KEY=
